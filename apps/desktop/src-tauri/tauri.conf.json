{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lectern",
  "version": "0.7.0",
  "identifier": "ai.lectern.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Lectern",
        "width": 1280,
        "height": 840,
        "minWidth": 760,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ShrimpScript/lectern/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc5MjlERUE3OTcxNTQ0RTkKUldUcFJCV1hwOTRwZVZkTWpiN0dtTXVDUEZhbWw3cDhTa2Y2cGZjNUFrWlVNc2ZaZTBwQ0lteG0K"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "createUpdaterArtifacts": true,
    "icon": ["icons/icon.png"],
    "category": "DeveloperTool",
    "shortDescription": "An engine for your AI",
    "longDescription": "Lectern wraps the AI coding agent you already pay for with persistent memory, learned skills, and adaptive context — local-first."
  }
}
